<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="20dp"
    android:background="#f5f5f5">

    <!-- 标题 -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="ESP8266 Servo Controller"
        android:textSize="24sp"
        android:textColor="#333333"
        android:textStyle="bold"
        android:gravity="center"
        android:layout_marginBottom="20dp"/>

    <!-- 当前位置显示 -->
    <TextView
        android:id="@+id/tvPosition"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Position: 90°"
        android:textSize="48sp"
        android:textColor="#007bff"
        android:textStyle="bold"
        android:gravity="center"
        android:layout_marginBottom="20dp"/>

    <!-- 滑块控制 -->
    <SeekBar
        android:id="@+id/sbServo"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:min="0"
        android:max="180"
        android:progress="90"
        android:layout_marginBottom="20dp"/>

    <!-- 预设角度按钮 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center"
        android:layout_marginBottom="20dp">

        <Button
            android:id="@+id/btn0"
            android:layout_width="60dp"
            android:layout_height="40dp"
            android:text="0°"
            android:background="#007bff"
            android:textColor="#ffffff"
            android:layout_margin="5dp"/>

        <Button
            android:id="@+id/btn45"
            android:layout_width="60dp"
            android:layout_height="40dp"
            android:text="45°"
            android:background="#007bff"
            android:textColor="#ffffff"
            android:layout_margin="5dp"/>

        <Button
            android:id="@+id/btn90"
            android:layout_width="60dp"
            android:layout_height="40dp"
            android:text="90°"
            android:background="#007bff"
            android:textColor="#ffffff"
            android:layout_margin="5dp"/>

        <Button
            android:id="@+id/btn135"
            android:layout_width="60dp"
            android:layout_height="40dp"
            android:text="135°"
            android:background="#007bff"
            android:textColor="#ffffff"
            android:layout_margin="5dp"/>

        <Button
            android:id="@+id/btn180"
            android:layout_width="60dp"
            android:layout_height="40dp"
            android:text="180°"
            android:background="#007bff"
            android:textColor="#ffffff"
            android:layout_margin="5dp"/>
    </LinearLayout>

    <!-- 手动输入区域 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="#ffffff"
        android:padding="20dp"
        android:layout_marginTop="20dp">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Manual Input"
            android:textSize="18sp"
            android:textColor="#333333"
            android:textStyle="bold"
            android:layout_marginBottom="15dp"/>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center">

            <EditText
                android:id="@+id/etManual"
                android:layout_width="100dp"
                android:layout_height="40dp"
                android:hint="0-180"
                android:inputType="number"
                android:gravity="center"
                android:layout_marginRight="10dp"/>

            <Button
                android:id="@+id/btnSend"
                android:layout_width="80dp"
                android:layout_height="40dp"
                android:text="Send"
                android:background="#007bff"
                android:textColor="#ffffff"/>
        </LinearLayout>
    </LinearLayout>

    <!-- 服务器连接区域 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="#ffffff"
        android:padding="20dp"
        android:layout_marginTop="20dp">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Server Connection"
            android:textSize="18sp"
            android:textColor="#333333"
            android:textStyle="bold"
            android:layout_marginBottom="15dp"/>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center">

            <EditText
                android:id="@+id/etServerAddress"
                android:layout_width="200dp"
                android:layout_height="40dp"
                android:hint="192.168.4.1"
                android:inputType="textUri"
                android:gravity="center"
                android:layout_marginRight="10dp"/>

            <Button
                android:id="@+id/btnConnect"
                android:layout_width="80dp"
                android:layout_height="40dp"
                android:text="Connect"
                android:background="#28a745"
                android:textColor="#ffffff"/>
        </LinearLayout>
    </LinearLayout>

</LinearLayout>